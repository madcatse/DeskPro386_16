 +MWE* /A31*  A23*  A22*  A21*  A20*  A19* /A18             ;00FB0000H 256K
 +MWE* /A31*  A23*  A22*  A21*  A20*  A19*  A18* /A17       ;00FC0000H 128K
 +MWE* /A31*  A23*  A22*  A21*  A20*  A19*  A18*  A17* /ROM ;00FE0000H 128K

