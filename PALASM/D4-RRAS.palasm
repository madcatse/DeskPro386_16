 + RFSH                                                 ;REFRESH

RSl =
  /A31* /A23* /A22* /A21* A20* FA20                     ;00l00000H l024K
  + RFSH                                                ;REFRESH

PARWR =
   MWE* A31* A23* A22* /A21* /A20* /A19* /A18* /A17     ;80COOOOOH 128K

PARRD =
   MRD* A31* A23* A22* /A21* /A20* /A19* /A18* /A17     ;80C00000H 128K

